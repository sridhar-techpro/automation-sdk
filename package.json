{
  "name": "automation-sdk",
  "version": "1.0.0",
  "description": "Production-grade Automation SDK",
  "main": "dist/core/sdk.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=tests/unit --runInBand --forceExit"
  },
  "dependencies": {
    "puppeteer-core": "^22.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "puppeteer": "^22.0.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testTimeout": 60000
  }
}
