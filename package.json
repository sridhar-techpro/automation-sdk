{
  "name": "automation-sdk",
  "version": "1.0.0",
  "description": "Production-grade Automation SDK",
  "main": "dist/core/sdk.js",
  "types": "dist/core/sdk.d.ts",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "pretest": "pnpm run build",
    "test": "jest --runInBand --forceExit",
    "test:e2e": "jest tests/e2e --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:e2e-extension": "jest tests/e2e-extension --runInBand --forceExit",
    "build:extension": "tsc -p extension/tsconfig.json && node scripts/package-extension.js",
    "validate": "ts-node --project tsconfig.scripts.json scripts/validate.ts",
    "generate-extension-report": "ts-node --project tsconfig.scripts.json scripts/generate-extension-report.ts",
    "start:chrome": "chrome --remote-debugging-port=9222"
  },
  "dependencies": {
    "puppeteer-core": "^22.0.0"
  },
  "devDependencies": {
    "@puppeteer/browsers": "^2.13.0",
    "@types/chrome": "^0.1.40",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "dotenv": "^17.4.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testTimeout": 60000
  }
}
